{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env*", "tsconfig.base.json", "biome.json"],
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "public/**",
        "index.html",
        "tsconfig.json",
        "vite.config.ts",
        "package.json"
      ],
      "outputs": ["dist/**", ".wrangler/dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "tests/**", "vitest.config.ts"],
      "outputs": ["coverage/**"]
    },
    "deploy": {
      "dependsOn": ["build", "lint", "typecheck", "test"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
